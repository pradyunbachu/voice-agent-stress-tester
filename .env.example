# Copy this file to ".env" and fill in your real key. ".env" is gitignored, so the
# real secret never gets committed; this template (no secret) is safe to commit.
# Get a key at https://console.deepgram.com/
DEEPGRAM_API_KEY=your_key_here

# Groq (LLM "brain"). Get a key at https://console.groq.com/keys
GROQ_API_KEY=your_key_here
